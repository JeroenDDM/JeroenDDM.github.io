{
    "name": "Queue Transfer Demo",
    "version": "1.0.0",
    "integrationType": "widget",
    "url": "https://jeroenddm.github.io/",
    "sandbox": "allow-forms,allow-modals,allow-popups,allow-presentation,allow-same-origin,allow-scripts,allow-downloads",
    "displayType": "standalone",
    "lifecycle": {
        "ephemeral": true,
        "hooks": {
            "bootstrap": true,
            "focus": true,
            "blur": true,
            "stop": true
        }
    },
    "icon": {
        "vector": "",
        "24x24": "",
        "36x36": "",
        "48x48": "",
        "72x72": ""
    },
    "permissions": [
        "conversation",
        "routing:queue:view",
        "alerting",
        "analytics"
    ],
    "groups": []
} 